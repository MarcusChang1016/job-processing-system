{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "WorkerOptions": {
    "PollingIntervalSeconds": 3,
    "ProcessingDelaySeconds": 2,
    "RetryCooldownSeconds": 30,
    "MaxRetryCount": 3,
    "StuckJobTimeoutSeconds": 30
  }
}
